# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ===== Database =====
DB_NAME=puduvandi
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ===== JWT =====
# Generate a fresh one per environment — never reuse the same secret across
# dev/staging/prod, and never commit the real value:
#   openssl rand -base64 48
JWT_SECRET=

# staging | production — SecurityStartupValidator refuses to boot with the
# placeholder JWT secret when this is exactly "production".
PUDUVANDI_ENV=staging

# ===== OTP =====
# Keep mock mode on for staging/demo unless you want real SMS OTPs.
OTP_MOCK_ENABLED=true
OTP_MOCK_VALUE=123456

# ===== SMS/WhatsApp provider =====
# No provider is wired in yet (Twilio was removed). NotificationService logs
# every send attempt as a non-retryable failure until a replacement is chosen.

# ===== Payments (Razorpay) =====
# true = booking creation auto-confirms instantly, no gateway call (default).
# false = booking sits PAYMENT_PENDING until a real Razorpay payment is verified —
# requires RAZORPAY_KEY_ID/RAZORPAY_KEY_SECRET below (test keys from your Razorpay
# dashboard's Settings -> API Keys; never commit the real Key Secret).
PAYMENT_MOCK_ENABLED=true
PAYMENT_EXPIRY_MINUTES=15
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
