# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ===== Database =====
DB_NAME=puduvandi
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ===== JWT =====
# Generate a fresh one per environment — never reuse the same secret across
# dev/staging/prod, and never commit the real value:
#   openssl rand -base64 48
JWT_SECRET=

# staging | production — SecurityStartupValidator refuses to boot with the
# placeholder JWT secret when this is exactly "production".
PUDUVANDI_ENV=staging

# ===== OTP =====
# Keep mock mode on for staging/demo unless you want real SMS OTPs.
OTP_MOCK_ENABLED=true
OTP_MOCK_VALUE=123456

# ===== Twilio (leave blank to no-op; required for real SMS/WhatsApp) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
